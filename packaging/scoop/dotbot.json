{
    "version": "3.1.0",
    "description": "Structured AI-assisted development framework with two-phase execution and web dashboard",
    "homepage": "https://github.com/andresharpe/dotbot",
    "license": "MIT",
    "url": "https://github.com/andresharpe/dotbot/releases/download/v3.1.0/dotbot-3.1.0.zip",
    "hash": {
        "url": "https://github.com/andresharpe/dotbot/releases/download/v3.1.0/dotbot-3.1.0.zip.sha256"
    },
    "extract_dir": "dotbot-3.1.0",
    "suggest": {
        "PowerShell 7+": "pwsh"
    },
    "installer": {
        "script": [
            "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$dir\\install.ps1\""
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Item -Path \"$env:USERPROFILE\\dotbot\" -Recurse -Force -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "github": "https://github.com/andresharpe/dotbot"
    },
    "autoupdate": {
        "url": "https://github.com/andresharpe/dotbot/releases/download/v$version/dotbot-$version.zip",
        "extract_dir": "dotbot-$version",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
